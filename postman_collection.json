            },
            "url": "{{baseUrl}}/groups/{{groupId}}"
          }
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "List devices",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{firebaseIdToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/devices"
          }
        },
        {
          "name": "Get device by path id",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{firebaseIdToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/devices/{{deviceId}}"
          }
        },
        {
          "name": "Create device (user)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{firebaseIdToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{deviceId}}\",\n  \"device_name\": \"Sensor 1\",\n  \"group_id\": null,\n  \"plant_type\": 1,\n  \"soil_type\": 1,\n  \"location\": \"POINT(-122.084 37.421)\",\n  \"location_notes\": \"Backyard\",\n  \"operational_status\": 1,\n  \"firmware_version\": \"1.0.0\"\n}"
            },
            "url": "{{baseUrl}}/devices"
          }
        },
        {
          "name": "Create device (Admin — set user_id)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{firebaseIdToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{deviceId}}\",\n  \"user_id\": \"{{targetUserId}}\",\n  \"device_name\": \"Sensor for user\"\n}"
            },
            "url": "{{baseUrl}}/devices"
          }
        },
        {
          "name": "Update device",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{firebaseIdToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_name\": \"Updated name\",\n  \"group_id\": null,\n  \"plant_type\": 1,\n  \"soil_type\": 1,\n  \"location\": \"POINT(-122.09 37.42)\",\n  \"location_notes\": \"Moved\",\n  \"operational_status\": 1,\n  \"firmware_version\": \"1.0.1\",\n  \"last_sync\": \"2026-04-02T15:00:00Z\",\n  \"configured_at\": \"2026-04-01T10:00:00Z\"\n}"
            },
            "url": "{{baseUrl}}/devices/{{deviceId}}"
          }
        }
      ]
    }
  ]
}
