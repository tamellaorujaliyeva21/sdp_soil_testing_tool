          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{firebaseIdToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"group_name\": \"Garden A\",\n  \"notes\": \"Optional notes\",\n  \"location\": \"POINT(-122.084 37.421)\"\n}"
            },
            "url": "{{baseUrl}}/groups"
          }
        },
        {
          "name": "Update group",
          "request": {
